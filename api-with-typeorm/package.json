    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "typeorm": "0.3.20",
    "reflect-metadata": "^0.2.2",
    "pg": "^8.20.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.22.1",
    "morgan": "^1.10.0",
    "tsx": "^4.21.0"
  }
}
